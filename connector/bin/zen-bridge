#!/usr/bin/env node
const fs = require('fs');
const path = require('path');
const os = require('os');

const PORTFILE = path.join(os.homedir(), '.zen-bridge-port');
const REQUEST_TIMEOUT_MS = 30_000;

function usage() {
  console.log(`Usage: zen-bridge <action> [options]

Actions:
  tabs                          List all tabs
  axtree    --tab <id> [--limit <n>] [--depth <n>]  Get accessible tree
  click     --tab <id> --ref <r>  Click element by ref
  scroll    --tab <id> --x <n> --y <n>
  scroll-into-view --tab <id> --ref <r>
  screenshot --tab <id>         Capture visible tab (base64)
  runjs     --tab <id> --code <js>

Options:
  -j, --json    Output raw JSON
`);
  process.exit(1);
}

function getPort() {
  if (!fs.existsSync(PORTFILE)) { console.error('No port file. Is Zen running with the extension?'); process.exit(1); }
  return fs.readFileSync(PORTFILE, 'utf8').trim();
}

function parsePositiveInteger(name, value) {
  const parsed = Number.parseInt(value, 10);

  if (!Number.isInteger(parsed) || parsed <= 0) {
    throw new Error(`--${name} must be a positive integer`);
  }

  return parsed;
}

function buildRequest(action, flags) {
  switch (action) {
    case 'tabs':
      return { action: 'tabs', request: {} };
    case 'axtree': {
      if (!flags.tab) usage();

      const request = { tabId: parsePositiveInteger('tab', flags.tab) };
      const payload = {};

      if (flags.limit != null) {
        payload.maxResults = parsePositiveInteger('limit', flags.limit);
      }

      if (flags.depth != null) {
        payload.maxDepth = parsePositiveInteger('depth', flags.depth);
      }

      if (Object.keys(payload).length > 0) {
        request.payload = payload;
      }

      return { action: 'axtree', request };
    }
    case 'click':
      if (!flags.tab || !flags.ref) usage();
      return { action: 'click', request: { tabId: parsePositiveInteger('tab', flags.tab), payload: { ref: flags.ref } } };
    case 'scroll':
      if (!flags.tab) usage();
      return { action: 'scroll', request: { tabId: parsePositiveInteger('tab', flags.tab), payload: { x: +(flags.x || 0), y: +(flags.y || 0) } } };
    case 'scroll-into-view':
      if (!flags.tab || !flags.ref) usage();
      return { action: 'scrollIntoView', request: { tabId: parsePositiveInteger('tab', flags.tab), payload: { ref: flags.ref } } };
    case 'screenshot':
      if (!flags.tab) usage();
      return { action: 'screenshot', request: { tabId: parsePositiveInteger('tab', flags.tab) } };
    case 'runjs':
      if (!flags.tab || !flags.code) usage();
      return { action: 'runjs', request: { tabId: parsePositiveInteger('tab', flags.tab), payload: { code: flags.code } } };
    default:
      usage();
  }
}

function wsSend(action, payload = {}) {
  return new Promise((res, rej) => {
    const WebSocket = require('ws');
    const ws = new WebSocket('ws://localhost:' + getPort());
    const id = 'c' + Date.now();
    const timer = setTimeout(() => { ws.close(); rej(new Error('timeout')); }, REQUEST_TIMEOUT_MS);
    ws.on('open', () => ws.send(JSON.stringify({ id, action, ...payload })));
    ws.on('message', d => { clearTimeout(timer); ws.close(); res(JSON.parse(d)); });
    ws.on('error', e => { clearTimeout(timer); rej(e); });
  });
}

async function main() {
  const args = process.argv.slice(2);
  if (args.length === 0) usage();

  const action = args[0];
  const flags = {};
  for (let i = 1; i < args.length; i++) {
    if (args[i].startsWith('--')) flags[args[i].slice(2)] = args[++i];
    else if (args[i] === '-j' || args[i] === '--json') flags.json = true;
  }

  const request = buildRequest(action, flags);
  const res = await wsSend(request.action, request.request);

  if (action === 'screenshot' && res.ok) {
    const m = res.result.match(/^data:image\/\w+;base64,(.+)/);
    if (m) {
      const buf = Buffer.from(m[1], 'base64');
      const out = flags.output || path.join(os.tmpdir(), `zen-bridge-${Date.now()}.png`);
      fs.writeFileSync(out, buf);
      res.result = out;
    }
  }

  if (flags.json) { console.log(JSON.stringify(res, null, 2)); }
  else if (res.ok) { console.log(res.result); }
  else { console.error('Error:', res.error); process.exit(1); }
}

if (require.main === module) {
  main().catch(e => { console.error(e.message); process.exit(1); });
} else {
  module.exports = {
    buildRequest,
    parsePositiveInteger,
    REQUEST_TIMEOUT_MS,
  };
}
