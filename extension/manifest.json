{
  "manifest_version": 2,
  "name": "Zen Bridge",
  "version": "1.0.2",
  "description": "Bridge Zen Browser to external tools via Native Messaging and WebSocket.",
  "background": {
    "scripts": ["background.js"],
    "persistent": true
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["axtree.js", "content.js"],
      "run_at": "document_end",
      "all_frames": false
    }
  ],
  "permissions": ["tabs", "activeTab", "<all_urls>", "nativeMessaging"],
  "browser_specific_settings": {
    "gecko": {
      "id": "zen-bridge@yachiyo.local"
    }
  }
}
