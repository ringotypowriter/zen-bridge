{
  "manifest_version": 2,
  "name": "Zen Bridge",
  "version": "1.0.7",
  "description": "Bridge Zen Browser to external tools via Native Messaging and WebSocket.",
  "background": {
    "scripts": ["background.js"],
    "persistent": true
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["axtree.js", "content.js"],
      "run_at": "document_end",
      "all_frames": false
    }
  ],
  "permissions": ["tabs", "activeTab", "<all_urls>", "nativeMessaging", "downloads"],
  "browser_action": {
    "default_title": "Zen Bridge",
    "default_popup": "onboarding.html"
  },
  "web_accessible_resources": ["onboarding.html", "onboarding.js"],
  "browser_specific_settings": {
    "gecko": {
      "id": "zen-bridge@yachiyo.local",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
